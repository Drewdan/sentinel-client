{
    "name": "drewdan/sentinel-client",
    "description": "Ships your Laravel application's logs to a Sentinel ingest endpoint.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "logging", "sentinel"],
    "authors": [
        {
            "name": "Andrew Arscott"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "sirbrillig/phpcs-variable-analysis": "^2.11",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Drewdan\\SentinelClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Drewdan\\SentinelClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs --standard=phpcs.xml --runtime-set ignore_warnings_on_exit true",
        "cs:fix": "phpcbf --standard=phpcs.xml --runtime-set ignore_warnings_on_exit true"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Drewdan\\SentinelClient\\SentinelClientServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
